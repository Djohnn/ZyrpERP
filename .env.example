# Zyrp — exemplo de variáveis de ambiente
# Copie para .env e preencha. NUNCA versione o .env real.

# Django
DJANGO_SETTINGS_MODULE=config.settings.local
SECRET_KEY=troque-por-uma-chave-secreta-forte
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000

# PostgreSQL (usado em local/test/production)
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_EXTERNAL_PORT=5433
POSTGRES_DB=zyrp
POSTGRES_USER=zyrp
POSTGRES_PASSWORD=zyrp
DATABASE_URL=postgres://zyrp:zyrp@localhost:5433/zyrp

# Papel de runtime: nunca deve ser superuser, owner ou BYPASSRLS
POSTGRES_APP_USER=zyrp_app
POSTGRES_APP_PASSWORD=zyrp_app_dev

# Papel de testes: pode criar o banco efêmero, mas nunca ignora RLS
POSTGRES_TEST_USER=zyrp_test
POSTGRES_TEST_PASSWORD=zyrp_test_dev

# Redis (cache e broker Celery)
REDIS_URL=redis://localhost:6380/0
CELERY_BROKER_URL=redis://localhost:6380/1
CELERY_RESULT_BACKEND=redis://localhost:6380/2

# Observabilidade
LOG_LEVEL=INFO
SENTRY_DSN=

# Configuração da aplicação
DEFAULT_FROM_EMAIL=no-reply@zyrp.local
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# Gere com Fernet.generate_key(); nunca versione a chave usada em produção
MFA_ENCRYPTION_KEY=
AUTH_TOKEN_TTL_MINUTES=30
EMAIL_MFA_TTL_MINUTES=10
EMAIL_MFA_MAX_ATTEMPTS=5
EMAIL_MFA_RESEND_COOLDOWN_SECONDS=60

# Somente para o comando local seed_tenants; nunca use credencial real
SEED_ADMIN_PASSWORD=
